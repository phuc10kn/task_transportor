{
  "name": "@task-transportor/admin-web",
  "version": "0.2.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build": "node scripts/check.js",
    "lint": "node scripts/check.js",
    "typecheck": "node scripts/check.js",
    "e2e": "playwright test",
    "e2e:backlog-actions": "playwright test --grep backlog",
    "e2e:cis-issue-editor": "playwright test --grep issue-editor",
    "e2e:issue-recovery": "playwright test --grep issue-editor",
    "e2e:translation": "playwright test --grep translation",
    "e2e:translation-glossary": "playwright test --grep glossary",
    "e2e:install": "playwright install chromium",
    "ci": "npm run build"
  },
  "dependencies": {
    "@tabler/core": "1.4.0",
    "markdown-it": "^14.3.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
