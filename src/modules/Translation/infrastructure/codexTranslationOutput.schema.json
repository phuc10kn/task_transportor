{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["translated_text", "confidence", "warnings", "preserved_blocks"],
  "properties": {
    "translated_text": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preserved_blocks": {
      "type": "boolean"
    }
  }
}
